{
  "name": "gongtu-web",
  "version": "0.1.0",
  "private": true,
  "description": "公途 Web 前端与空间几何实验室依赖",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "doctor": "node tools/doctor.mjs",
    "dev": "node tools/dev-server.mjs ensure",
    "dev:static": "node tools/dev-server.mjs ensure",
    "dev:open": "node tools/dev-server.mjs open",
    "preview": "node tools/dev-server.mjs open",
    "preview:lesson": "node tools/dev-server.mjs open '/reasoning-lesson.html?case=pyramid-cylinder-001&verify=front-facing&fresh=preview'",
    "preview:three": "node tools/dev-server.mjs open /three-view-training.html",
    "preview:quantity": "node tools/dev-server.mjs open /quantity-practice.html",
    "preview:quantity-review": "node tools/dev-server.mjs open '/ai-coach-demo.html?module=quantity.practice'",
    "ai:configure": "python3 tools/configure-ai-key.py",
    "dev:status": "node tools/dev-server.mjs status",
    "dev:stop": "node tools/dev-server.mjs stop",
    "python:venv": "node tools/python-venv.mjs",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "deps:check": "npm ls --all",
    "quantity:status": "node tools/quantity-bank-status.mjs",
    "quantity:pipeline": "node tools/quantity-bank-pipeline.mjs --skip-build",
    "quantity:pipeline:full": "node tools/quantity-bank-pipeline.mjs",
    "quantity:ci": "node tools/quantity-bank-ci.mjs",
    "quantity:vision:prepare": "node tools/quantity-bank-render-repair-assets.mjs --limit=all --target=all --dpi=180 && node tools/quantity-bank-vision-repair-batch.mjs --limit=all",
    "quantity:vision:prepare:answers": "node tools/quantity-bank-vision-repair-batch.mjs --limit=all --lane=answer_recovery",
    "quantity:vision:prepare:options": "node tools/quantity-bank-vision-repair-batch.mjs --limit=all --lane=options_recovery",
    "quantity:vision:prepare:images": "node tools/quantity-bank-vision-repair-batch.mjs --limit=all --lane=image_crop_and_structure_repair",
    "quantity:vision:execute": "node tools/quantity-bank-vision-repair-batch.mjs --limit=all --execute --concurrency=3",
    "quantity:test:vision-import": "node tools/quantity-bank-test-vision-import-gates.mjs",
    "test:geometry": "node --experimental-loader ./tests/three-absolute-loader.mjs --test ./tests/*.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "manifold-3d": "^3.5.1",
    "three": "0.185.0",
    "three-bvh-csg": "0.0.18",
    "three-mesh-bvh": "0.9.10",
    "vue": "3.5.21"
  }
}
