{
  "name": "gongtu-desktop",
  "version": "1.0.0",
  "description": "公途学习平台 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.gongtu.desktop",
    "productName": "公途",
    "mac": {
      "category": "public.app-category.education",
      "target": ["dmg", "zip"]
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
