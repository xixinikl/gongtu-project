# 片段阅读/申论共用的 OpenAI 兼容模型配置示例。
# 只复制为本地 .env；不要把真实密钥提交到 Git。
DEEPSEEK_API_KEY=replace-me
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
VERBAL_AI_TIMEOUT_SECONDS=30
VERBAL_AI_MAX_RETRIES=1

# 生产运行安全配置。请生成独立随机值，不要直接使用示例。
GONTU_ENV=production
GONTU_JWT_SECRET=replace-with-at-least-32-random-bytes
GONTU_DB_PATH=/srv/gongtu/data/gongtu.db
GONTU_CORS_ORIGINS=https://your-gongtu-domain.example
# 只有应用确实位于这些反向代理之后时才填写，多个地址用英文逗号分隔。
GONTU_TRUSTED_PROXIES=127.0.0.1
