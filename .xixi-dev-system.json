{
  "schemaVersion": 1,
  "projectName": "gongtu-project",
  "repository": "https://github.com/xixinikl/gongtu-project",
  "defaultBranch": "main",
  "runtime": {
    "manager": "uv",
    "python": "3.11",
    "startCommand": "{python} -m uvicorn main:app --host 127.0.0.1 --port $PORT",
    "doctorCommand": "{python} -m pytest backend/tests",
    "portEnvironment": "PORT",
    "dataNamespaceEnvironment": "XDS_DATA_NAMESPACE",
    "workingDirectory": "backend",
    "requirements": [
      "backend/requirements.txt"
    ]
  },
  "collaboration": {
    "focusAuthors": [
      "inernoro"
    ],
    "riskPathPatterns": [
      "auth",
      "payment",
      "migration",
      "deploy",
      "secret"
    ]
  },
  "data": {
    "environment": {
      "GONTU_DB_PATH": ".xds/data/{namespace}/data.db"
    }
  },
  "learning": {
    "projectRetrospectiveDirectory": "doc/retrospectives",
    "sharedProfileRepository": "https://github.com/xixinikl/xixi-agent-profile"
  },
  "quality": {
    "acceptanceCommand": "bash .agent-factory/scripts/daily-check.sh --date {date}",
    "lowRiskAutofixCommand": "bash .agent-factory/scripts/apply-autofix.sh --checks .agent-factory/out/{date}/checks.json --risk .agent-factory/out/{date}/risk.json --out .agent-factory/out/{date}/autofix.json",
    "autofixPaths": [
      "backend"
    ]
  }
}
